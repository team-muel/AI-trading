# Supabase
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="xxxxx"   # 봇 서버에서만 사용. 절대 프론트에 두지 마.

# Trading config
EXCHANGE="binance"
SYMBOL="BTC/USDT"
TIMEFRAME="30m"

# Strategy params (Pine에서 가져온 값)
CVD_LEN=19
DELTA_COEF=1.0
RISK_PCT=2.0
TP_PCT=4.0
SL_PCT=2.0
LEVERAGE=20

# Binance API (Futures)
BINANCE_API_KEY="xxxxx"
BINANCE_API_SECRET="xxxxx"
BINANCE_FUTURES=true   # true면 USDT-M 선물, false면 현물

# Runner
POLL_SECONDS=20        # 30m이지만 DB에 새 캔들 들어왔는지 20초마다 확인
CANDLE_LOOKBACK=400    # CVD/SMA 계산에 필요한 히스토리
DRY_RUN=true           # true면 주문 안 넣고 로그만
