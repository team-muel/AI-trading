# Supabase
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="xxxxx"

# Exchange
EXCHANGE="binance"
BINANCE_API_KEY="xxxxx"
BINANCE_API_SECRET="xxxxx"
BINANCE_FUTURES=true

# Symbols / timeframe
SYMBOLS="BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,XRP/USDT"
TIMEFRAME="30m"

# Strategy params
CVD_LEN=19
DELTA_COEF=1.0
RISK_PCT=2.0
TP_PCT=4.0
SL_PCT=2.0
LEVERAGE=20

# Runner (bot)
POLL_SECONDS=20
CANDLE_LOOKBACK=400
DRY_RUN=true
INITIAL_CAPITAL=3000
EQUITY_SPLIT=true

# Ingest (candles)
INGEST_POLL_SECONDS=30
BACKFILL_DAYS=365
MAX_PAGES_PER_SYMBOL=200
